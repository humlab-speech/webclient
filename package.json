{
  "name": "webclient-ng",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration=production",
    "datalab-build": "ng build --configuration=datalab",
    "visp-build": "npm run php:vendor && ng build --configuration=visp",
    "visp-demo-build": "ng build --configuration=visp-demo",
    "visp-pdf-server-build": "ng build --configuration=visp-pdf-server",
    "visp-local-build": "ng build --configuration=visp.dev",
    "devbuild": "ng build --watch",
    "visp-dev": "npm run php:vendor && ng build --configuration=visp.dev --watch",
    "datalab-dev": "ng build --configuration=datalab.dev --watch",
    "php:vendor": "composer install --no-interaction --prefer-dist"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@popperjs/core": "^2.11.8",
    "@swimlane/ngx-datatable": "^20.1.0",
    "angular-notifier": "^14.0.0",
    "font-awesome": "^4.7.0",
    "js-cookie": "^3.0.1",
    "jszip": "^3.7.1",
    "nanoid": "^5.0.8",
    "ngx-dropzone": "^3.0.0",
    "ngx-popperjs": "^17.0.0",
    "normalize.css": "^8.0.1",
    "rxjs": "^7.5.7",
    "shepherd.js": "^14.1.0",
    "speechrecorderng": "^3.0.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.23",
    "@angular/cli": "^20.3.23",
    "@angular/compiler-cli": "^20.3.18",
    "@types/node": "^14.14.28",
    "typescript": "~5.8.3"
  }
}